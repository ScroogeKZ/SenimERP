// apps/senim-erp-api/prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Customer {
  id        String   @id @default(uuid())
  crmId     String?  @unique // Link to CRM client card
  name      String
  bin       String   @unique // BIN/IIN (94-V compliance)
  address   String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  invoices  Invoice[]
  waybills  Waybill[]
  acts      ServiceAct[]
  creditNotes CreditNote[]
}

model Invoice {
  id             String            @id @default(uuid())
  number         String            @unique // Readable invoice number e.g. "INV-2026-0001"
  customerId     String
  customer       Customer          @relation(fields: [customerId], references: [id])
  amount         Decimal           @db.Decimal(15, 2) // Total invoice amount
  vatAmount      Decimal           @db.Decimal(15, 2) // Total VAT amount
  paidAmount     Decimal           @default(0.00) @db.Decimal(15, 2)
  status         InvoiceStatus     @default(DRAFT)
  issueDate      DateTime          @default(now())
  dueDate        DateTime
  items          InvoiceLineItem[]
  signedXml      String?           @db.Text // Signed XML storage
  signature      DocumentSignature?
  esfDocument    EsfDocument?
  crmDealId      String?           // Back-link to CRM deal
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  payments       InvoicePayment[]
  creditNotes    CreditNote[]
}

model InvoicePayment {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(15, 2)
  paidAt      DateTime @default(now())
  method      String?
  referenceId String?
  createdAt   DateTime @default(now())
}

model InvoiceLineItem {
  id                String    @id @default(uuid())
  invoiceId         String
  invoice           Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sku               String    // SKU of item referencing CRM catalog
  crmProductId      String?   // Optional direct link to CRM product
  name              String    // Snapshot of the name at document creation
  quantity          Decimal   @db.Decimal(12, 3)
  price             Decimal   @db.Decimal(15, 2) // Price excluding VAT
  originalPrice     Decimal?  @db.Decimal(15, 2)
  discountAmount    Decimal   @default(0.00) @db.Decimal(15, 2)
  discountPercent   Decimal   @default(0.00) @db.Decimal(5, 2)
  dealCurrency      String?
  dealCurrencyPrice Decimal?  @db.Decimal(15, 4)
  exchangeRate      Decimal?  @db.Decimal(12, 6)
  exchangeRateDate  DateTime?
  vatRate           Decimal   @db.Decimal(5, 2)  // e.g. 12.00%
  vatAmount         Decimal   @db.Decimal(15, 2)
  totalAmount       Decimal   @db.Decimal(15, 2) // Line total including VAT
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model Waybill {
  id             String            @id @default(uuid())
  number         String            @unique // Readable waybill number e.g. "WAY-2026-0001"
  customerId     String
  customer       Customer          @relation(fields: [customerId], references: [id])
  warehouseId    String?
  warehouse      Warehouse?        @relation(fields: [warehouseId], references: [id])
  amount         Decimal           @db.Decimal(15, 2)
  vatAmount      Decimal           @db.Decimal(15, 2)
  status         WaybillStatus     @default(DRAFT)
  issueDate      DateTime          @default(now())
  items          WaybillLineItem[]
  signedXml      String?           @db.Text
  signature      DocumentSignature?
  esfDocument    EsfDocument?
  crmDealId      String?
  rmas           Rma[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model WaybillLineItem {
  id                String    @id @default(uuid())
  waybillId         String
  waybill           Waybill   @relation(fields: [waybillId], references: [id], onDelete: Cascade)
  sku               String
  crmProductId      String?
  name              String
  quantity          Decimal   @db.Decimal(12, 3)
  price             Decimal   @db.Decimal(15, 2)
  originalPrice     Decimal?  @db.Decimal(15, 2)
  discountAmount    Decimal   @default(0.00) @db.Decimal(15, 2)
  discountPercent   Decimal   @default(0.00) @db.Decimal(5, 2)
  dealCurrency      String?
  dealCurrencyPrice Decimal?  @db.Decimal(15, 4)
  exchangeRate      Decimal?  @db.Decimal(12, 6)
  exchangeRateDate  DateTime?
  vatRate           Decimal   @db.Decimal(5, 2)
  vatAmount         Decimal   @db.Decimal(15, 2)
  totalAmount       Decimal   @db.Decimal(15, 2)
}

enum WaybillStatus {
  DRAFT
  ISSUED
  DELIVERED
  CANCELLED
}

model ServiceAct {
  id             String            @id @default(uuid())
  number         String            @unique // e.g. "ACT-2026-0001"
  customerId     String
  customer       Customer          @relation(fields: [customerId], references: [id])
  amount         Decimal           @db.Decimal(15, 2)
  vatAmount      Decimal           @db.Decimal(15, 2)
  status         ActStatus         @default(DRAFT)
  issueDate      DateTime          @default(now())
  items          ActLineItem[]
  signedXml      String?           @db.Text
  signature      DocumentSignature?
  esfDocument    EsfDocument?
  crmDealId      String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model ActLineItem {
  id                String    @id @default(uuid())
  actId             String
  act               ServiceAct @relation(fields: [actId], references: [id], onDelete: Cascade)
  sku               String    // SKU of service
  crmProductId      String?
  name              String    // Service description
  quantity          Decimal   @db.Decimal(12, 3)
  price             Decimal   @db.Decimal(15, 2)
  originalPrice     Decimal?  @db.Decimal(15, 2)
  discountAmount    Decimal   @default(0.00) @db.Decimal(15, 2)
  discountPercent   Decimal   @default(0.00) @db.Decimal(5, 2)
  dealCurrency      String?
  dealCurrencyPrice Decimal?  @db.Decimal(15, 4)
  exchangeRate      Decimal?  @db.Decimal(12, 6)
  exchangeRateDate  DateTime?
  vatRate           Decimal   @db.Decimal(5, 2)
  vatAmount         Decimal   @db.Decimal(15, 2)
  totalAmount       Decimal   @db.Decimal(15, 2)
}

enum ActStatus {
  DRAFT
  ISSUED
  SIGNED_BY_CUSTOMER
  CANCELLED
}

model EsfDocument {
  id            String       @id @default(uuid())
  invoiceId     String?      @unique
  invoice       Invoice?     @relation(fields: [invoiceId], references: [id])
  waybillId     String?      @unique
  waybill       Waybill?     @relation(fields: [waybillId], references: [id])
  actId         String?      @unique
  act           ServiceAct?  @relation(fields: [actId], references: [id])
  creditNoteId  String?      @unique
  creditNote    CreditNote?  @relation(fields: [creditNoteId], references: [id])
  status        EsfStatus    @default(PENDING)
  esfRegNumber  String?      // регистрационный номер ЭСФ в ИС ЭСФ (после успешной подачи)
  requestXml    String?      @db.Text   // сформированный и подписанный XML, отправленный в ИС ЭСФ
  responseXml   String?      @db.Text   // сырой ответ системы — для разбора ошибок вручную
  errorMessage  String?
  submittedAt   DateTime?
  confirmedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum EsfStatus {
  PENDING       // сформирован, ещё не отправлен
  SUBMITTED     // отправлен в ИС ЭСФ, ждём подтверждения
  REGISTERED    // зарегистрирован, получен esfRegNumber — юридически значим
  REJECTED      // отклонён ИС ЭСФ (ошибка валидации, невалидный БИН контрагента и т.п.)
  FAILED        // техническая ошибка при отправке (таймаут, недоступность сервиса) — подлежит повтору
}

model DocumentSignature {
  id          String      @id @default(uuid())
  invoiceId   String?     @unique
  invoice     Invoice?    @relation(fields: [invoiceId], references: [id])
  waybillId   String?     @unique
  waybill     Waybill?    @relation(fields: [waybillId], references: [id])
  actId       String?     @unique
  act         ServiceAct? @relation(fields: [actId], references: [id])
  creditNoteId String?    @unique
  creditNote  CreditNote? @relation(fields: [creditNoteId], references: [id])
  signedBy    String      // Signer Name
  iin         String      // Signer IIN
  certSerial  String      // Cert Serial
  signedAt    DateTime    @default(now())
}

model ProcessedEvent {
  id          String   @id // Event ID from Integration Bus (for deduplication)
  eventType   String
  processedAt DateTime @default(now())
}

model StockItem {
  id           String   @id @default(uuid())
  sku          String
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  crmProductId String?
  quantity     Decimal  @default(0) @db.Decimal(12, 3)
  reserved     Decimal  @default(0) @db.Decimal(12, 3)
  updatedAt    DateTime @updatedAt

  @@unique([sku, warehouseId])
}

model StockMovement {
  id          String   @id @default(uuid())
  sku         String
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  quantity    Decimal  @db.Decimal(12, 3)
  type        String   // receipt | shipment
  referenceId String?  // waybillId for shipment or purchaseOrderId / receipt reference
  createdAt   DateTime @default(now())
}

model Supplier {
  id          String   @id @default(uuid())
  name        String
  bin         String?  @unique
  address     String?
  email       String?
  phone       String?
  bankAccount String?
  bankBik     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders   PurchaseOrder[]
  supplierInvoices SupplierInvoice[]
}

model PurchaseOrder {
  id               String              @id @default(uuid())
  number           String              @unique // e.g. "PO-2026-0001"
  supplierId       String
  supplier         Supplier            @relation(fields: [supplierId], references: [id])
  warehouseId      String?
  warehouse        Warehouse?          @relation(fields: [warehouseId], references: [id])
  status           PurchaseOrderStatus @default(DRAFT)
  expectedDate     DateTime?
  items            PurchaseOrderItem[]
  supplierInvoices SupplierInvoice[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  sku             String
  crmProductId    String?
  name            String
  quantity        Decimal       @db.Decimal(12, 3)
  receivedQty     Decimal       @default(0) @db.Decimal(12, 3)
  price           Decimal       @db.Decimal(15, 2)
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model SupplierInvoice {
  id              String                @id @default(uuid())
  number          String                @unique // "SUP-INV-2026-0001"
  supplierId      String
  supplier        Supplier              @relation(fields: [supplierId], references: [id])
  purchaseOrderId String?               // необязательная связь, счёт может быть не привязан к конкретному заказу
  purchaseOrder   PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id])
  amount          Decimal               @db.Decimal(15, 2)
  paidAmount      Decimal               @default(0.00) @db.Decimal(15, 2)
  status          SupplierInvoiceStatus @default(UNPAID)
  issueDate       DateTime              @default(now())
  dueDate         DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  payments SupplierPayment[]
}

model SupplierPayment {
  id                String          @id @default(uuid())
  supplierInvoiceId String
  supplierInvoice   SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id])
  amount            Decimal         @db.Decimal(15, 2)
  paidAt            DateTime        @default(now())
  method            String?         // banking, cash — свободная строка, как paymentMethod у Invoice в CRM
  referenceId       String?         // номер платёжки/квитанции
  createdAt         DateTime        @default(now())
}

enum SupplierInvoiceStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  CANCELLED
}

model Warehouse {
  id             String          @id @default(uuid())
  name           String
  code           String          @unique
  isDefault      Boolean         @default(false)
  createdAt      DateTime        @default(now())
  stockItems     StockItem[]
  stockMovements StockMovement[]
  waybills       Waybill[]
  purchaseOrders PurchaseOrder[]
  rmaLines       RmaLine[]
}

enum RmaStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

model Rma {
  id          String      @id @default(uuid())
  number      String      @unique
  waybillId   String
  waybill     Waybill     @relation(fields: [waybillId], references: [id])
  status      RmaStatus   @default(DRAFT)
  reason      String?
  confirmedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  lines       RmaLine[]
  creditNote  CreditNote?
}

model RmaLine {
  id          String    @id @default(uuid())
  rmaId       String
  rma         Rma       @relation(fields: [rmaId], references: [id], onDelete: Cascade)
  sku         String
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  quantity    Decimal   @db.Decimal(12, 3)
  price       Decimal?  @db.Decimal(15, 2)
  vatRate     Decimal?  @db.Decimal(5, 2)
  vatAmount   Decimal?  @db.Decimal(15, 2)
  totalAmount Decimal?  @db.Decimal(15, 2)
}

enum CreditNoteStatus {
  DRAFT
  ISSUED
  CANCELLED
}

model CreditNote {
  id          String              @id @default(uuid())
  number      String              @unique
  rmaId       String              @unique
  rma         Rma                 @relation(fields: [rmaId], references: [id])
  invoiceId   String?
  invoice     Invoice?            @relation(fields: [invoiceId], references: [id])
  customerId  String
  customer    Customer            @relation(fields: [customerId], references: [id])
  amount      Decimal             @db.Decimal(15, 2)
  vatAmount   Decimal             @db.Decimal(15, 2)
  status      CreditNoteStatus    @default(DRAFT)
  issueDate   DateTime            @default(now())
  items       CreditNoteLineItem[]
  signedXml   String?             @db.Text
  signature   DocumentSignature?
  esfDocument EsfDocument?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model CreditNoteLineItem {
  id                String     @id @default(uuid())
  creditNoteId      String
  creditNote        CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  sku               String
  crmProductId      String?
  name              String
  quantity          Decimal    @db.Decimal(12, 3)
  price             Decimal    @db.Decimal(15, 2)
  vatRate           Decimal    @db.Decimal(5, 2)
  vatAmount         Decimal    @db.Decimal(15, 2)
  totalAmount       Decimal    @db.Decimal(15, 2)
  discountAmount    Decimal    @default(0.00) @db.Decimal(15, 2)
  dealCurrency      String?
  dealCurrencyPrice Decimal?   @db.Decimal(15, 4)
  exchangeRate      Decimal?   @db.Decimal(12, 6)
  exchangeRateDate  DateTime?
}

model TenantProfile {
  id           String   @id @default("tenant_profile")
  companyName  String
  companyBin   String
  legalAddress String?
  directorName String?
  directorIin  String?
  updatedAt    DateTime @updatedAt
}



